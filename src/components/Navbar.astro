---
import DropdownIcon from "../icons/Dropdown.astro";
import MailIcon from "../icons/Mail.astro";
import { t } from "../i18n/translations";
import type { Lang } from "../i18n/translations";

interface Props {
  lang: Lang;
  otherLangUrl: string;
}

const { lang, otherLangUrl } = Astro.props;
const tr = t(lang);
const otherLangLabel = lang === "es" ? "EN" : "ES";

const sections = [
  { name: tr.navHome, href: "#" },
  { name: tr.navProjects, href: "#projects" },
  { name: tr.navAbout, href: "#detailedaboutme" },
];
---

<div
  id="navbar"
  class="z-50 flex flex-row flex-wrap items-center justify-between w-full gap-4 py-4 transition-all duration-300 ease-in-out h-max text-text md:flex-nowrap md:px-20 md:max-w-6xl lg:mx-auto"
>
  <div class="flex flex-row items-center justify-between w-full">
    <a
      class="flex flex-row items-center gap-1 transition-colors duration-200 hover:text-accent-hover md:w-max"
      href="mailto:christopherglood@gmail.com"
    >
      <MailIcon classes="w-4 h-4" />
      <span>christopherglood@gmail.com</span>
    </a>
    <button
      aria-label={tr.navOpen}
      aria-expanded="false"
      id="links-toggle"
      class="p-2 transition-colors duration-200 border border-transparent rounded hover:bg-primary-hover md:hidden md:w-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-interactive focus-visible:ring-offset-2 focus-visible:ring-offset-background"
    >
      <DropdownIcon />
    </button>
  </div>

  <div
    class="order-last hidden w-full mb-2 overflow-hidden rounded-lg shadow-md bg-background-500 md:mb-0 md:p-0 md:flex md:flex-row md:justify-end md:bg-transparent md:shadow-none"
    id="links"
  >
    <ul
      class="flex flex-col items-center justify-between text-center sm:flex-row md:gap-10 md:w-fit"
    >
      {
        sections.map((section) => (
          <li class="w-full transition-colors duration-200 hover:bg-primary-hover md:hover:bg-transparent">
             <a
               class="inline-block w-full py-2.5 hover:text-accent-hover transition-colors duration-200 md:w-max focus:outline-none focus-visible:ring-2 focus-visible:ring-interactive focus-visible:rounded focus-visible:ring-offset-2 focus-visible:ring-offset-background"
               href={section.href}
             >
              {section.name}
            </a>
          </li>
        ))
      }

      <li>
        <a
          href={otherLangUrl}
          aria-label={tr.navLangToggle}
          class="flex items-center justify-center w-10 h-10 font-bold transition-colors duration-200 border rounded-lg hover:cursor-pointer border-accent hover:text-accent-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-interactive focus-visible:ring-offset-2 focus-visible:ring-offset-background text-accent-900"
        >
          {otherLangLabel}
        </a>
      </li>
    </ul>
  </div>
</div>

<script>
  const toggle = document.getElementById("links-toggle");
  toggle?.addEventListener("click", () => {
    const links = document.getElementById("links");
    const isHidden = links?.classList.toggle("hidden");
    // Actualizar aria-expanded para accesibilidad
    toggle?.setAttribute("aria-expanded", isHidden ? "false" : "true");
  });
</script>

<style></style>
